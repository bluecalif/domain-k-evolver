{
  "domain": "japan-travel",
  "version": 0,
  "core_categories": [
    "transport",
    "regulation",
    "pass-ticket"
  ],
  "scope_boundary": {
    "includes": [
      "일본 국내 교통수단",
      "숙박 유형 및 예약",
      "관광지 입장/운영",
      "식당/음식 문화",
      "입국/비자/세관 규정",
      "패스/티켓 상품",
      "통신 (SIM/eSIM/Wi-Fi)",
      "결제 수단"
    ],
    "excludes": [
      "출발국→일본 항공권 비교",
      "여행 보험 상품 비교",
      "일본어 학습",
      "역사/문화 심층 해설",
      "장기 체류/취업/유학 비자"
    ],
    "boundary_rule": "일본 도착 후~출국까지 여행자 실용 정보. 2024년 이후 유효 정보만."
  },
  "categories": [
    {
      "slug": "transport",
      "description": "교통수단/노선/서비스"
    },
    {
      "slug": "accommodation",
      "description": "숙박 유형/서비스"
    },
    {
      "slug": "attraction",
      "description": "관광지/명소"
    },
    {
      "slug": "dining",
      "description": "식당/음식 유형/에티켓"
    },
    {
      "slug": "regulation",
      "description": "입국/비자/세관/법규"
    },
    {
      "slug": "pass-ticket",
      "description": "교통패스/관광패스 상품"
    },
    {
      "slug": "connectivity",
      "description": "통신/인터넷"
    },
    {
      "slug": "payment",
      "description": "결제수단"
    }
  ],
  "fields": [
    {
      "name": "price",
      "type": "object",
      "categories": ["*"],
      "description": "가격 정보",
      "condition_axes": ["season", "route", "pass_type", "traveler_type"],
      "default_risk": "financial",
      "default_utility": "high"
    },
    {
      "name": "hours",
      "type": "string",
      "categories": ["attraction", "dining"],
      "description": "운영시간",
      "condition_axes": ["season", "day_of_week"],
      "default_risk": "convenience",
      "default_utility": "high"
    },
    {
      "name": "policy",
      "type": "string",
      "categories": ["regulation", "pass-ticket"],
      "description": "규정/조건",
      "condition_axes": ["traveler_type", "route"],
      "default_risk": "policy",
      "default_utility": "high"
    },
    {
      "name": "location",
      "type": "object",
      "categories": ["attraction", "dining", "accommodation"],
      "description": "위치",
      "default_risk": "convenience",
      "default_utility": "medium"
    },
    {
      "name": "duration",
      "type": "string",
      "categories": ["transport", "pass-ticket"],
      "description": "소요/유효기간",
      "condition_axes": ["pass_type", "route"],
      "default_risk": "convenience",
      "default_utility": "medium"
    },
    {
      "name": "eligibility",
      "type": "string",
      "categories": ["pass-ticket", "regulation"],
      "description": "이용 자격",
      "condition_axes": ["traveler_type", "nationality"],
      "default_risk": "policy",
      "default_utility": "critical"
    },
    {
      "name": "how_to_use",
      "type": "string",
      "categories": ["transport", "payment", "connectivity"],
      "description": "이용 방법",
      "default_risk": "convenience",
      "default_utility": "medium"
    },
    {
      "name": "etiquette",
      "type": "string",
      "categories": ["dining", "accommodation"],
      "description": "에티켓/매너",
      "default_risk": "convenience",
      "default_utility": "low"
    },
    {
      "name": "tips",
      "type": "string",
      "categories": ["*"],
      "description": "실용 팁",
      "default_risk": "informational",
      "default_utility": "low"
    },
    {
      "name": "acceptance",
      "type": "string",
      "categories": ["payment"],
      "description": "사용 가능 범위",
      "condition_axes": ["geography", "traveler_type"],
      "default_risk": "financial",
      "default_utility": "high"
    },
    {
      "name": "where_to_buy",
      "type": "string",
      "categories": ["pass-ticket", "connectivity"],
      "description": "구매처/방법",
      "condition_axes": ["geography"],
      "default_risk": "convenience",
      "default_utility": "medium"
    }
  ],
  "relations": [
    {
      "name": "covers_route",
      "source": "transport",
      "target": "transport",
      "description": "노선 커버 구간"
    },
    {
      "name": "valid_for",
      "source": "pass-ticket",
      "target": "transport",
      "description": "패스 이용 가능 교통"
    },
    {
      "name": "located_in",
      "source": [
        "attraction",
        "dining"
      ],
      "target": "region",
      "description": "위치 관계"
    },
    {
      "name": "accepted_at",
      "source": "payment",
      "target": [
        "transport",
        "dining",
        "attraction"
      ],
      "description": "결제수단 사용처"
    }
  ],
  "axes": [
    {
      "name": "category",
      "description": "정보 카테고리 (기존 categories와 동일)",
      "anchors": [
        "transport",
        "accommodation",
        "attraction",
        "dining",
        "regulation",
        "pass-ticket",
        "connectivity",
        "payment"
      ],
      "required": true,
      "note": "entity_key에서 자동 추출"
    },
    {
      "name": "geography",
      "description": "지역성 — 정보가 적용되는 지리적 범위",
      "anchors": [
        "tokyo",
        "osaka",
        "kyoto",
        "rural",
        "nationwide"
      ],
      "required": true,
      "note": "entity_key 또는 KU 내용에서 추론. 지역 무관 시 nationwide"
    },
    {
      "name": "condition",
      "description": "조건/시즌/채널 — 정보가 유효한 특정 조건",
      "anchors": [
        "peak-season",
        "off-season",
        "weekday",
        "weekend",
        "online",
        "in-person"
      ],
      "required": false,
      "note": "해당되는 경우만 태깅. 조건 무관 시 생략"
    },
    {
      "name": "risk",
      "description": "리스크 유형 — GU가 다루는 리스크 분류",
      "anchors": [
        "safety",
        "financial",
        "policy",
        "convenience",
        "informational"
      ],
      "required": true,
      "note": "기존 GU risk_level 필드와 동일 체계"
    }
  ],
  "axis_meta": {
    "version": "1.0",
    "created_at": "2026-03-04",
    "relation_to_categories": "category 축은 기존 Category×Field 매트릭스의 행 차원. geography/condition/risk는 추가 차원으로, GU 커버리지를 다축으로 추적한다.",
    "bootstrap_compatibility": "기존 Bootstrap 알고리즘(category×field 기반 GU 생성)은 변경 없이 유지. axes는 생성된 GU에 사후 태깅하여 커버리지 분석에 활용."
  },
  "canonical_key_rule": {
    "format": "japan-travel:{category}:{slug}",
    "slug_rules": "영문 소문자, 하이픈 구분, 공식 영문 명칭 기반"
  },
  "field_adjacency": {
    "_comment": "S3-T3: field adjacency rule engine seed. {source_field: [next_fields]}. category override가 _global보다 우선.",
    "_global": {
      "price": ["how_to_use", "where_to_buy", "policy"],
      "hours": ["price", "location", "tips"],
      "policy": ["eligibility", "how_to_use", "price"],
      "location": ["hours", "tips", "price"],
      "tips": ["price", "how_to_use", "policy"],
      "how_to_use": ["policy", "tips", "where_to_buy"],
      "where_to_buy": ["price", "how_to_use", "acceptance"],
      "eligibility": ["policy", "where_to_buy", "price"],
      "acceptance": ["where_to_buy", "how_to_use", "policy"],
      "duration": ["price", "policy", "eligibility"],
      "etiquette": ["tips", "hours", "price"]
    },
    "transport": {
      "price": ["duration", "how_to_use", "where_to_buy"],
      "duration": ["price", "policy", "how_to_use"],
      "how_to_use": ["price", "policy", "where_to_buy"]
    },
    "pass-ticket": {
      "price": ["duration", "eligibility", "where_to_buy"],
      "eligibility": ["price", "policy", "where_to_buy"],
      "duration": ["price", "eligibility", "policy"]
    },
    "dining": {
      "price": ["hours", "location", "etiquette"],
      "hours": ["price", "location", "tips"],
      "etiquette": ["tips", "price", "hours"]
    },
    "accommodation": {
      "price": ["location", "hours", "tips"],
      "location": ["price", "hours", "tips"]
    },
    "attraction": {
      "price": ["hours", "location", "tips"],
      "hours": ["price", "location", "tips"],
      "location": ["hours", "price", "tips"]
    },
    "payment": {
      "acceptance": ["where_to_buy", "how_to_use", "policy"],
      "how_to_use": ["acceptance", "policy", "where_to_buy"],
      "where_to_buy": ["acceptance", "how_to_use"]
    },
    "connectivity": {
      "price": ["how_to_use", "where_to_buy", "policy"],
      "how_to_use": ["price", "where_to_buy", "tips"],
      "where_to_buy": ["price", "how_to_use"]
    },
    "regulation": {
      "policy": ["eligibility", "how_to_use", "price"],
      "eligibility": ["policy", "price", "how_to_use"]
    }
  }
}
